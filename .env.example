# ── Gemini Provider ─────────────────────────────────────────────────────────
# Allowed values: ai_studio (default) | vertex
GEMINI_PROVIDER=ai_studio

# ── Google AI Studio (GEMINI_PROVIDER=ai_studio) ─────────────────────────────
# GOOGLE_API_KEY is preferred; legacy GEMINI_API_KEY is also accepted.
GOOGLE_API_KEY=your-gemini-api-key-here

# ── Vertex AI (GEMINI_PROVIDER=vertex) ───────────────────────────────────────
# Generate the base64 value with:  base64 -w0 service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=<base64-encoded service account JSON>

# ── Optional — defaults shown ────────────────────────────────────────────────
# COUNSELAI_DATABASE_URL=sqlite+aiosqlite:///counselai.db
# COUNSELAI_LOG_LEVEL=INFO
# COUNSELAI_DEBUG=false
# COUNSELAI_CORS_ORIGINS=https://your-domain.com
# COUNSELAI_MAX_SESSION_DURATION_SECONDS=300
# COUNSELAI_SESSION_WRAPUP_SECONDS=90
# COUNSELAI_GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# COUNSELAI_GEMINI_SYNTHESIS_MODEL=gemini-2.5-flash
